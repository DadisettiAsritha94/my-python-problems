marks = []
for i in range(5):
    marks.append(int(input(f"Enter mark {i+1}: ")))
total = sum(marks)
average = total / 5
print("Total:", total)
print("Average:", average)
if average >= 90:
    print("Grade: A")
elif average >= 75:
    print("Grade: B")
elif average >= 60:
    print("Grade: C")
else:
    print("Grade: Fail")

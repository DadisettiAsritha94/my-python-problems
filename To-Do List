tasks = []
while True:
    print("\n1.Add\n2.View\n3.Remove\n4.Exit")
    choice = input("Enter choice: ")
    if choice == '1':
        task = input("Enter task: ")
        tasks.append(task)
    elif choice == '2':
        print(tasks)
    elif choice == '3':
        task = input("Enter task to remove: ")
        if task in tasks:
            tasks.remove(task)
    elif choice == '4':
        break

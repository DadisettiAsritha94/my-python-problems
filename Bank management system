balance = 1000
while True:
    print("\n1.Deposit\n2.Withdraw\n3.Check Balance\n4.Exit")
    choice = input("Enter choice: ")
    if choice == '1':
        amount = float(input("Enter amount: "))
        balance += amount
    elif choice == '2':
        amount = float(input("Enter amount: "))
        if amount <= balance:
            balance -= amount
        else:
            print("Insufficient Balance")
    elif choice == '3':
        print("Balance:", balance)
    elif choice == '4':
        break
